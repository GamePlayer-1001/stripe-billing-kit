# ── Stripe Billing Kit 环境变量模板 ─────────────────────────
# 复制为 .env.local(Next.js)或 .env(Express),填入所有者交接卡中的值。
# 规则:仅 publishable key 可加 NEXT_PUBLIC_ 前缀暴露给前端;其余绝不进前端与 git。

# 该产品专属 Stripe account(或 sandbox)的密钥
STRIPE_SECRET_KEY=sk_test_xxx

# webhook 签名密钥:
#   本地开发 = `stripe listen` 启动时打印的 whsec_
#   线上部署 = Dashboard → Developers → Webhooks → endpoint 的 Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 前端可公开的 key(Express/非 Next 项目可去掉 NEXT_PUBLIC_ 前缀,按各自框架约定注入前端)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# 应用对外地址(用于拼 checkout 成功/取消回跳地址)
APP_URL=http://localhost:3000
